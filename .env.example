# Server-side only. Never commit real keys.

# CPA relay for gpt-image-2
CPA_BASE_URL=http://your-cpa-host:8317/v1
CPA_API_KEY=sk-...
# Optional default model name
CPA_MODEL=gpt-image-2

# App login gate (password-only login page at /login)
# Set any strong random string; users enter it on /login to receive an auth cookie.
APP_PASSWORD=change-me-to-a-long-random-string
